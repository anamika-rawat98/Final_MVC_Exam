@model IEnumerable<BankingSystem.Web.Models.Transaction>

@{
    ViewData["Title"] = "Transaction History";
    decimal runningBalance = ViewBag.CurrentBalance;
    // To show "Balance After" correctly, we need the chronological list
    var chronologicalTransactions = Model.OrderByDescending(t => t.TransactionDate).ToList();
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Transaction History - @ViewBag.AccountNumber</h3>
            <span class="badge bg-light text-dark fs-6">Current Balance: @runningBalance.ToString("C")</span>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th class="text-end">Amount</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in chronologicalTransactions)
                    {
                        <tr>
                            <td>@item.TransactionDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>
                                <span class="badge @(item.TransactionType == BankingSystem.Web.Models.TransactionType.Deposit ? "bg-success" : "bg-danger")">
                                    @item.TransactionType
                                </span>
                            </td>
                            <td class="text-end fw-bold @(item.TransactionType == BankingSystem.Web.Models.TransactionType.Deposit ? "text-success" : "text-danger")">
                                @(item.TransactionType == BankingSystem.Web.Models.TransactionType.Deposit ? "+" : "-")@item.Amount.ToString("C")
                            </td>
                            <td>@(string.IsNullOrEmpty(item.Description) ? "---" : item.Description)</td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">No transactions found for this account.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer">
            <a asp-controller="Account" asp-action="Details" asp-route-id="@ViewBag.AccountId" class="btn btn-secondary">Back to Account Details</a>
        </div>
    </div>
</div>
